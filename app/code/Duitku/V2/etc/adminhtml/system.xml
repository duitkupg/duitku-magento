<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
  <system>
    <section id="payment">
      <group id="duitku_setting" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
        <label>Duitku Payment Gateway</label>
        <fieldset_css>complex duitku-admin</fieldset_css>
		<frontend_model>Duitku\V2\Block\Adminhtml\Config\Fieldset</frontend_model>
		<comment>Easy and powerful. Get up and running in minutes. Accept credit and debit cards, e-wallets, bank transfers, and send bulk payments via a single integration - and monitor it all in one place.</comment>
		<attribute type="displayIn">recommended_solutions</attribute>

		<field id="merchantnumber" type="text" sortOrder="4" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Merchant number:</b>]]></label>
			<comment><![CDATA[The unique merchantnumber received from the payment system. If you don't know your merchantnumber please Contact Duitku Payment Provider]]></comment>
			<config_path>payment/duitku_setting/merchantnumber</config_path>
		</field>
		<field id="api_key" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
			<label>API Secret Key</label>
			<config_path>payment/duitku_setting/api_key</config_path>
			<comment>Test/Live Secret Key</comment>
		</field>
		<field id="payment_mode" translate="label" type="select" sortOrder="6" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Live Mode:</b>]]></label>
			<source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
			<comment><![CDATA[If Payment Mode Enable this redirect To live otherwise Setup Sandbox Mode.]]></comment>
			<config_path>payment/duitku_setting/payment_mode</config_path>
		</field>  
		<field id="order_status" type="select" sortOrder="11" showInDefault="7" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Order Status After Payment:</b>]]></label>
			<source_model>Magento\Sales\Model\Config\Source\Order\Status\Processing</source_model>
			<config_path>payment/duitku_setting/order_status</config_path>
			<comment><![CDATA[The order status after payment is compleated]]></comment>
		</field> 
		<field id="sendmailorderconfirmation" type="select" sortOrder="8" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Send Email Order Confirmation:</b>]]></label>
			<comment><![CDATA[Enabling this setting will result in an order confirmation is e-mailed to the customer as the payment is made.]]></comment>
			<source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
			<config_path>payment/duitku_setting/sendmailorderconfirmation</config_path>
		</field>
		<field id="instantinvoice" type="select" sortOrder="9" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Instant invoice:</b>]]></label>
			<comment><![CDATA[This is used if you wish to create an invoice once the payment has been authorized.]]></comment>
			<source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
			<config_path>payment/duitku_setting/instantinvoice</config_path>
		</field>
		<field id="instantinvoicemail" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[<b>Instant invoice mail:</b>]]></label>
			<comment><![CDATA[If instant invoice then send invoice to customer.]]></comment>
			<source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
			<config_path>payment/duitku_setting/instantinvoicemail</config_path>
		</field>

		<group id="duitku_listcc" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[Credit Card]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_creditcard.xml"/>
			<include path="Duitku_V2::system/duitku_mg.xml"/>
		</group>
		<group id="duitku_listva" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[Virtual Account]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
			<attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_briva.xml"/>
			<include path="Duitku_V2::system/duitku_vaatmbersama.xml"/>
			<include path="Duitku_V2::system/duitku_vabca.xml"/>
			<include path="Duitku_V2::system/duitku_bnc.xml"/>
			<include path="Duitku_V2::system/duitku_vabni.xml"/>
			<include path="Duitku_V2::system/duitku_vabsi.xml"/>
			<include path="Duitku_V2::system/duitku_vacimbniaga.xml"/>
			<include path="Duitku_V2::system/duitku_vadanamon.xml"/>
			<include path="Duitku_V2::system/duitku_vamandiri.xml"/>
			<include path="Duitku_V2::system/duitku_vamaybank.xml"/>
			<include path="Duitku_V2::system/duitku_vapermata.xml"/>
			<include path="Duitku_V2::system/duitku_vasampoerna.xml"/>
		</group>
		<group id="duitku_listewallet" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[E-Wallet]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_bcaklikpay.xml"/>
			<include path="Duitku_V2::system/duitku_shopeepayapps.xml"/>
			<include path="Duitku_V2::system/duitku_linkajaapps.xml"/>
			<include path="Duitku_V2::system/duitku_linkajaappsfixed.xml"/>
			<include path="Duitku_V2::system/duitku_dana.xml"/>
			<include path="Duitku_V2::system/duitku_ovo.xml"/>
			<include path="Duitku_V2::system/duitku_jeniuspay.xml"/>
		</group>
		<group id="duitku_listritel" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[Ritel]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_indomaret.xml"/>
			<include path="Duitku_V2::system/duitku_ritel.xml"/>
			<include path="Duitku_V2::system/duitku_pospay.xml"/>
		</group>
		<group id="duitku_listqris" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[QRIS]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_linkajaqris.xml"/>
			<include path="Duitku_V2::system/duitku_nobuqris.xml"/>
			<include path="Duitku_V2::system/duitku_danaqris.xml"/>
			<include path="Duitku_V2::system/duitku_gudangvoucherqris.xml"/>
			<include path="Duitku_V2::system/duitku_shopeepayqris.xml"/>
			<include path="Duitku_V2::system/duitku_nusapayqris.xml"/>
		</group>
		<group id="duitku_listkredit" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[Paylater]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_atome.xml"/>
			<include path="Duitku_V2::system/duitku_indodana.xml"/>
		</group>
		<group id="duitku_listecommerce" translate="label" type="text" sortOrder="15" showInDefault="1" showInWebsite="1" showInStore="1">
			<label><![CDATA[E-Commerce]]></label>
			<frontend_model>\Magento\Config\Block\System\Config\Form\Fieldset</frontend_model>
            <attribute type="expanded">0</attribute>
			<include path="Duitku_V2::system/duitku_tokopediacardpayment.xml"/>
			<include path="Duitku_V2::system/duitku_tokopediaewallet.xml"/>
			<include path="Duitku_V2::system/duitku_tokopediaothers.xml"/>
		</group>
      </group>
    </section>
  </system>
</config>