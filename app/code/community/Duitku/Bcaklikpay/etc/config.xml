<?xml version="1.1"?>
<config>
    <modules>
        <Duitku_Bcaklikpay>
            <version>2.2.0</version>
        </Duitku_Bcaklikpay>
    </modules>
    <global>
        <blocks>
            <bcaklikpay>
                <class>Duitku_Bcaklikpay_Block</class>
            </bcaklikpay>
        </blocks>
        <models>
            <bcaklikpay>
                <class>Duitku_Bcaklikpay_Model</class>
            </bcaklikpay>
        </models>
        <helpers>
            <bcaklikpay>
                <class>Duitku_Bcaklikpay_Helper</class>
            </bcaklikpay>
        </helpers>
    </global>
    <default>
        <payment>
            <bcaklikpay>
                <active>0</active>
                <title>Duitku BCA Klikpay</title>
                <model>bcaklikpay/bcaklikpay</model> 
                <allowspecific>0</allowspecific>
                <apiurl>https://passport.duitku.com/webapi/</apiurl>
            </bcaklikpay>
        </payment>
    </default>
    <frontend>
       <routers>
          <bcaklikpay>
              <use>standard</use>
              <args>
                 <module>Duitku_Bcaklikpay</module>
                 <frontName>bcaklikpay</frontName>
              </args>
           </bcaklikpay>
       </routers>
    </frontend>
</config>