<?xml version="1.1"?>
<config>
    <modules>
        <Duitku_Indodana>
            <version>2.2.0</version>
        </Duitku_Indodana>
    </modules>
    <global>
        <blocks>
            <indodana>
                <class>Duitku_Indodana_Block</class>
            </indodana>
        </blocks>
        <models>
            <indodana>
                <class>Duitku_Indodana_Model</class>
            </indodana>
        </models>
        <helpers>
            <indodana>
                <class>Duitku_Indodana_Helper</class>
            </indodana>
        </helpers>
    </global>
    <default>
        <payment>
            <indodana>
                <active>0</active>
                <title>Duitku Indodana Payment</title>
                <model>indodana/indodana</model> 
                <allowspecific>0</allowspecific>
                <apiurl>https://passport.duitku.com/webapi/</apiurl>
            </indodana>
        </payment>
    </default>
    <frontend>
       <routers>
          <indodana>
              <use>standard</use>
              <args>
                 <module>Duitku_Indodana</module>
                 <frontName>indodana</frontName>
              </args>
           </indodana>
       </routers>
    </frontend>
</config>