<?xml version="1.1"?>
<config>
    <modules>
        <Duitku_Vabni>
            <version>2.2.0</version>
        </Duitku_Vabni>
    </modules>
    <global>
        <blocks>
            <vabni>
                <class>Duitku_Vabni_Block</class>
            </vabni>
        </blocks>
        <models>
            <vabni>
                <class>Duitku_Vabni_Model</class>
            </vabni>
        </models>
        <helpers>
            <vabni>
                <class>Duitku_Vabni_Helper</class>
            </vabni>
        </helpers>
    </global>
    <default>
        <payment>
            <vabni>
                <active>0</active>
                <title>Duitku BNI Virtual Account</title>
                <model>vabni/vabni</model> 
                <allowspecific>0</allowspecific>
                <apiurl>https://passport.duitku.com/webapi/</apiurl>
				<duitkuexpired>1440</duitkuexpired>
            </vabni>
        </payment>
    </default>
    <frontend>
       <routers>
          <vabni>
              <use>standard</use>
              <args>
                 <module>Duitku_Vabni</module>
                 <frontName>vabni</frontName>
              </args>
           </vabni>
       </routers>
    </frontend>
</config>